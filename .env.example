# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./botivate_master.db

# JWT & App Security
# In any non-"development" APP_ENV, the app REFUSES to start if these are left
# at their default values (see Settings.validate_production_secrets).
JWT_SECRET_KEY=change-this-to-a-random-32-character-string
APP_SECRET_KEY=change-this-to-a-strong-random-secret

# Environment: "development" (relaxed checks) or "production" (strict).
APP_ENV=development

# CORS — comma-separated allowed origins. Leave as "*" only in development.
# NOTE: when this is "*", credentialed CORS requests are disabled (browsers
# forbid "*" + credentials). Set explicit origins in production, e.g.:
#   ALLOWED_ORIGINS=https://fms.yourcompany.com,https://admin.yourcompany.com
ALLOWED_ORIGINS=*

# Rate limiting (auth endpoints) uses slowapi with IN-MEMORY storage by default.
# This resets on every redeploy and is NOT shared across multiple workers or
# instances. For multi-instance deployments, back it with Redis.

# OpenAI LLM
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Fast LLM (Optional — used for data answers and policy queries. E.g. Cerebras or Groq)
# Cerebras Base URL: https://api.cerebras.ai/v1
# Groq Base URL: https://api.groq.com/openai/v1
FAST_LLM_API_KEY=
FAST_LLM_MODEL=
FAST_LLM_BASE_URL=

# Application
APP_NAME=Finance FMS Portal

# Google Sheets Configuration
# Get GOOGLE_SHEET_ID from URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=1E6HKeoYxOrroF-ogNpmyks-nuYX4f-iUjFMG7Fu2X_4
GOOGLE_EMPLOYEE_SHEET_NAME=RAW DATA
GOOGLE_ADMIN_SHEET_NAME=Admin

# Google Service Account JSON (paste entire JSON as single line)
# Download from Google Cloud Console → Service Accounts
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"hr-support-488005",...}

# Disable Google Auth for testing (set to false for production)
SKIP_GOOGLE_AUTH=false
