# ── Environments & secrets ────────────────────────────────
.env
.env.*
!.env.example
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Credentials & keys (note: *.json is broad — tracked JSON config files like
# package.json / tsconfig.json / vercel.json are re-included in their own
# folder's .gitignore, e.g. frontend/.gitignore)
*.json
!.env.example
credentials.json
service-account.json
token.pickle
token.json
oauth_*.json
.client_secret*.json
*.pem
*.key
*.cert

# ── Frontend (Vite app → Vercel) ──────────────────────────
# Track source; ignore only build artifacts.
frontend/node_modules/
frontend/dist/
frontend/.tsbuildinfo

# Old Replit UI workspace (nested git repo), superseded by frontend/.
Replit-UI/

